<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/stylr.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-zinc-900 text-white font-sans antialiased selection:bg-indigo-500 selection:text-white">
    <div
        class="min-h-screen flex flex-col items-center pt-20 px-6 pb-20 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-zinc-800 via-zinc-900 to-black">
        <div
            class="w-full max-w-md bg-zinc-800/40 backdrop-blur-xl border border-white/10 rounded-3xl shadow-2xl overflow-hidden mb-16 flex-shrink-0">
            <div class="p-8 sm:p-10">
                <div class="mb-8 text-center">
                    <h1
                        class="text-3xl font-extrabold bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
                        Create Task</h1>
                    <p class="text-zinc-400 mt-3 text-sm font-medium">Add a new task to your workspace</p>
                </div>
                <!-- here is the form data to create the task and send it to the server to save it in the database. -->
                <form action="/create" method="POST" class="space-y-6">
                    <div class="space-y-2 text-left">
                        <label for="title" class="block text-sm font-semibold text-zinc-300 ml-1">Task Title</label>
                        <input type="text" name="name" id="title" autocomplete="off"
                            class="w-full px-5 py-4 bg-zinc-900/50 border border-white/5 rounded-2xl focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500/50 transition-all duration-300 text-white placeholder-zinc-600 shadow-inner"
                            placeholder="e.g. Redesign landing page">
                    </div>

                    <div class="space-y-2 text-left">
                        <label for="details" class="block text-sm font-semibold text-zinc-300 ml-1">Task Details</label>
                        <textarea name="details" id="details" rows="4"
                            class="w-full px-5 py-4 bg-zinc-900/50 border border-white/5 rounded-2xl focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500/50 transition-all duration-300 text-white placeholder-zinc-600 resize-none shadow-inner"
                            placeholder="Describe what needs to be done..."></textarea>
                    </div>

                    <button type="submit"
                        class="w-full py-4 px-6 mt-4 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 hover:from-indigo-400 hover:via-purple-400 hover:to-pink-400 text-white font-bold rounded-2xl shadow-lg shadow-purple-500/25 hover:shadow-purple-500/40 transition-all duration-300 transform hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-zinc-900 focus:ring-purple-500">
                        Create Task
                    </button>
                </form>
            </div>
        </div>

        <!-- Tasks Display Section -->
        <div class="w-full max-w-5xl">
            <h2 class="text-3xl font-bold mb-8 text-white border-b border-white/10 pb-4">Your Tasks</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- handle the file showing part -->
                <% if (tasks && tasks.length> 0) { %>
                    <!-- if the task is found then it show how many times is created. -->
                    <% tasks.forEach(function(task) { %>
                        <div
                            class="bg-zinc-800/30 backdrop-blur-md border border-white/10 rounded-2xl p-6 shadow-xl hover:shadow-2xl hover:border-indigo-500/30 transition-all duration-300 transform hover:-translate-y-1 group flex flex-col relative overflow-hidden">

                            <div
                                class="absolute top-0 right-0 -mt-4 -mr-4 w-24 h-24 bg-indigo-500/20 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                            </div>

                            <h3
                                class="text-xl font-bold text-indigo-300 mb-3 group-hover:text-indigo-200 transition-colors z-10 break-words">
                                <%= task.title %>
                            </h3>
                            <p class="text-zinc-400 text-sm leading-relaxed mb-6 flex-grow z-10 break-words">
                                <%= task.details %>
                            </p>

                            <div class="flex justify-between items-center mt-auto z-10 pt-4 border-t border-white/5">
                                <span class="text-xs font-medium text-zinc-500 bg-zinc-900/50 px-3 py-1 rounded-full">
                                    <%= task.filename %>
                                </span>
                            </div>
                            <!-- FIX: use filename in route so backend can load exact file -->
                            <a href="/files/<%= encodeURIComponent(task.filename) %>"
                                class="text-indigo-400 text-sm font-semibold hover:underline mt-3 inline-block">
                                Read More
                            </a>
                        </div>
                    <% }) %>

                <!-- show that the task is not created yet -->
                <% } else { %>
                    <div
                        class="col-span-full flex flex-col items-center justify-center py-16 bg-zinc-800/20 rounded-3xl border border-white/5 border-dashed">
                        <div
                            class="w-16 h-16 rounded-full bg-zinc-800/80 flex items-center justify-center mb-4 border border-white/5 shadow-inner">
                            <svg class="w-8 h-8 text-zinc-500" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2">
                                </path>
                            </svg>
                        </div>
                        <p class="text-zinc-300 font-semibold text-lg">No tasks yet</p>
                        <p class="text-zinc-500 text-sm mt-1">Create your first task above</p>
                    </div>
                <% } %>
            </div>
        </div>
</body>

<script src="/javascripts/script.js"></script>

</html>